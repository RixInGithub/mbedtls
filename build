#!/usr/bin/env bash
# install |emsdk| before using this piece of crap idfk
# https://emscripten.org/docs/getting_started/downloads.html#installation-instructions-using-the-emsdk-recommended
set -euo pipefail
exp=_malloc,_free,_calloc,_realloc,_mbedtls_ssl_init
(cd mbedtls && make clean && emmake make lib -j4)
emcc mbedtls/library/*.a -o $1/mbedtls.js -s MODULARIZE=1 -s EXPORT_NAME=mbedtls -Oz -s EXPORTED_FUNCTIONS=$exp -s EXPORTED_RUNTIME_METHODS=addFunction,cwrap,memory -s EXPORT_ES6=1 -s ALLOW_MEMORY_GROWTH=1 -s ENVIRONMENT=web # contrary to @urish's belief, we dont need to order anything in here! just feed it an expansion and you're good to go!
mv $1/mbedtls.wasm $1/mbedtls.bin